# Local properties file - DO NOT commit to version control
# Copy this file to local.properties and fill in your values

# Android SDK location (automatically set by Android Studio)
# sdk.dir=/Users/username/Library/Android/sdk

# Google OAuth Web Client ID (from Firebase Console > Authentication > Sign-in methods > Google)
# This ID is used for Google Sign-In and should be kept private
WEB_CLIENT_ID=your-web-client-id-here.apps.googleusercontent.com
